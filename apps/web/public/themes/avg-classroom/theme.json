{
  "id": "avg-classroom",
  "name": "AVG Classroom",
  "version": "1.0.0",
  "author": { "name": "Alice", "id": "alice" },
  "description": "Anime classroom with 6 agent slots in visual-novel style.",
  "tags": ["anime", "classroom", "avg"],
  "preview": "preview.png",
  "license": "standard",

  "canvas": {
    "width": 1920,
    "height": 1072,
    "background": { "image": "bg.jpeg" }
  },
  "viewport": {
    "minZoom": 0.5,
    "maxZoom": 3,
    "defaultZoom": 1,
    "panBounds": true,
    "mobile": { "defaultZoom": 1.8, "pinchToZoom": true }
  },
  "layers": [],
  "zones": [],
  "furniture": [],
  "characters": {
    "atlas": "",
    "frameWidth": 0,
    "frameHeight": 0,
